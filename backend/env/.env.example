# ── Backend Environment Variables ─────────────────────────────────────────────

# Database Connection (PostgreSQL)
DATABASE_URL=host=postgres user=eventos_user password=change_me_in_production dbname=eventos_db port=5432 sslmode=disable

# Server Configuration
PORT=8080
ENV=development

# Logging
LOG_LEVEL=info

# Security
SESSION_SECRET=change_me_in_production_use_strong_random_string

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=15m

# Timeouts
READ_TIMEOUT=10s
WRITE_TIMEOUT=10s

# Application Timezone
TZ=America/Guayaquil
