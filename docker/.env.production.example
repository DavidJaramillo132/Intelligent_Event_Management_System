# Production Environment Template
# Copy this to .env and fill in with production values
# DO NOT commit this file to version control

# ── PostgreSQL Configuration ──────────────────────────────────────────────────
# Use a strong, random password (minimum 20 characters)
POSTGRES_USER=eventos_user
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_20_CHARS
POSTGRES_DB=eventos_db

# ── pgAdmin Configuration ──────────────────────────────────────────────────────
# Use a production email and strong password
PGADMIN_EMAIL=devops@yourdomain.com
PGADMIN_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_20_CHARS

# ── Backend API Configuration ──────────────────────────────────────────────────
PORT=8080
ENV=production

# ── Frontend Configuration ────────────────────────────────────────────────────
# This should point to your actual production API endpoint
VITE_API_URL=https://api.yourdomain.com/api

# ── Application Settings ──────────────────────────────────────────────────────
TIMEZONE=America/Guayaquil
LOG_LEVEL=warn  # Use 'warn' in production (not 'info' or 'debug')

# ── SSL/TLS Configuration ────────────────────────────────────────────────────
# These are handled by your reverse proxy (nginx/Traefik)
# Not needed in compose file, but reference for setup:
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# ── Database Backup Configuration ──────────────────────────────────────────────
# Configure automated backups (not in compose, for reference)
# BACKUP_SCHEDULE=daily
# BACKUP_RETENTION_DAYS=30
# BACKUP_PATH=/backups/postgresql

# ── Monitoring Configuration (Optional) ──────────────────────────────────────
# If using monitoring stack
# PROMETHEUS_SCRAPE_INTERVAL=15s
# GRAFANA_ADMIN_PASSWORD=STRONG_PASSWORD

# ── Session/Security Configuration ──────────────────────────────────────────
# Generated session secret (use: openssl rand -hex 32)
# SESSION_SECRET should be different from password!
# Set this in backend/.env, not docker/.env

# Important Notes:
# 1. Never use the same password for different services
# 2. Generate passwords with: openssl rand -hex 16
# 3. Rotate credentials every 90 days
# 4. Keep this file outside version control
# 5. Restrict file permissions: chmod 600 .env
# 6. Use a secrets manager (Vault, AWS Secrets, etc.) for production
# 7. Audit access to .env files regularly
